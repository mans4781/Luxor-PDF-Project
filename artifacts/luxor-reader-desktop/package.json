{
  "name": "@workspace/luxor-reader-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Luxor PDF Reader — Windows desktop wrapper for the luxor-pdf web app.",
  "main": "out/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/copy-assets.mjs",
    "build:web-bundle": "node ./scripts/build-web-bundle.mjs",
    "start": "pnpm run build && electron .",
    "dist": "pnpm run build && pnpm run build:web-bundle && electron-builder",
    "dist:win": "pnpm run build && pnpm run build:web-bundle && electron-builder --win --x64",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "icon:regen": "node ./scripts/build-icon.mjs",
    "dist:web-stub": "node ./scripts/build-web-installer.mjs"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.9.0"
  },
  "build": {
    "appId": "com.luxor.pdfreader",
    "productName": "Luxor PDF Reader",
    "copyright": "Copyright © 2026 Luxor PDF",
    "asar": true,
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "build/icon.ico",
      "package.json",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "web-bundle",
        "to": "web-bundle",
        "filter": [
          "**/*"
        ]
      }
    ],
    "fileAssociations": [
      {
        "ext": "pdf",
        "name": "PDF Document",
        "description": "PDF Document",
        "icon": "build/icon.ico",
        "role": "Viewer"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "Luxor PDF Reader Setup ${version}.${ext}",
      "publisherName": "Luxor PDF",
      "certificateFile": "${env.WIN_CSC_LINK}",
      "certificatePassword": "${env.WIN_CSC_KEY_PASSWORD}",
      "certificateSubjectName": "${env.WIN_CSC_SUBJECT_NAME}",
      "certificateSha1": "${env.WIN_CSC_SHA1}",
      "signingHashAlgorithms": [
        "sha256"
      ],
      "rfc3161TimeStampServer": "http://timestamp.digicert.com",
      "timeStampServer": "http://timestamp.digicert.com",
      "signDlls": false,
      "sign": "./scripts/sign-windows.cjs"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Luxor PDF Reader",
      "menuCategory": "Luxor",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "uninstallDisplayName": "Luxor PDF Reader",
      "deleteAppDataOnUninstall": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "mans4781",
        "repo": "luxor-reader-desktop",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3"
  }
}
