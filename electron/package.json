{
  "name": "lexsecure-pdf",
  "version": "1.0.0",
  "description": "LexSecure PDF — Secure PDF management desktop app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win portable --x64",
    "build:win32": "electron-builder --win portable --ia32"
  },
  "dependencies": {
    "express": "^4.21.2",
    "multer": "^2.0.2",
    "cors": "^2.8.5",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "electron": "^39.8.1",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.lexsecure.pdf",
    "productName": "LexSecure PDF",
    "copyright": "Copyright © 2025 LexSecure",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "server.js",
      "db.js",
      "icon.jpg",
      "public/**/*",
      "node_modules/**/*",
      "!node_modules/.cache/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.jpg",
      "forceCodeSigning": false,
      "certificateFile": null,
      "signingHashAlgorithms": null
    },
    "portable": {
      "artifactName": "LexSecure-PDF-Setup.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/favicon.ico",
      "uninstallerIcon": "public/favicon.ico",
      "artifactName": "LexSecure-PDF-Setup.exe"
    }
  }
}
