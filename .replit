modules = ["nodejs-24", "python-3.11", "postgresql-16"]

  [[artifacts]]
  id = "artifacts/api-server"

  [[artifacts]]
  id = "artifacts/mockup-sandbox"

  [deployment]
  router = "application"
  deploymentTarget = "autoscale"

  [deployment.postBuild]
  args = ["pnpm", "store", "prune"]
  env = { "CI" = "true" }

  [workflows]
runButton = "Project"

  [agent]
  stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["resend:1.0.0"]

  [postMerge]
  path = "scripts/post-merge.sh"
  timeoutMs = 20000

  [nix]
  channel = "stable-25_05"

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 6800

[[ports]]
localPort = 19050
externalPort = 3002

[[ports]]
localPort = 19051
externalPort = 6000

[[ports]]
localPort = 20963
externalPort = 3000

[[ports]]
localPort = 20964
externalPort = 5000

[[ports]]
localPort = 21447
externalPort = 3001

[[ports]]
localPort = 21448
externalPort = 5173

[[ports]]
localPort = 22843
externalPort = 3004

[[ports]]
localPort = 22844
externalPort = 3003

[[ports]]
localPort = 22845
externalPort = 4200

